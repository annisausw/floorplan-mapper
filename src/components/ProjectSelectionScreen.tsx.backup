/**
 * @file Project Selection Screen Component
 * @description UI for selecting and managing map projects
 */

import React, { useState, useEffect } from "react";
import { MapProject } from "../types";
import { apiService } from "../services/APIService";

interface ProjectSelectionScreenProps {
  user: string;
  onSelectProject: (id: string) => void;
  onLogout: () => void;
}

/**
 * ProjectSelectionScreen Component
 * Lists user's maps and allows create/delete operations
 */
export function ProjectSelectionScreen({
  user,
  onSelectProject,
  onLogout,
}: ProjectSelectionScreenProps) {
  const [projects, setProjects] = useState<MapProject[]>([]);
  const [loading, setLoading] = useState(true);

  // Load projects on mount
  useEffect(() => {
    loadProjects();
  }, []);

  async function loadProjects() {
    try {
      setLoading(true);
      const data = await apiService.listMaps();
      setProjects(data.sort((a, b) => b.updatedAt - a.updatedAt));
    } catch (err) {
      console.error("Failed to load projects:", err);
    } finally {
      setLoading(false);
    }
  }

  async function createProject() {
    const name = prompt("Enter new map name:", "Floor 1 Map");
    if (!name) return;

    try {
      const result = await apiService.createMap(name);
      onSelectProject(result.mapId);
    } catch (err) {
      console.error("Failed to create project:", err);
      alert("Failed to create map");
    }
  }

  async function deleteProject(id: string) {
    if (
      !confirm(
        "Are you sure you want to delete this map? This cannot be undone.",
      )
    ) {
      return;
    }

    try {
      await apiService.deleteMap(id);
      setProjects((p) => p.filter((proj) => proj.id !== id));
    } catch (err) {
      console.error("Failed to delete project:", err);
      alert("Failed to delete map");
    }
  }

  return (
    <div
      style={{
        padding: "60px 20px",
        fontFamily: "system-ui",
        background: "#f8fafc",
        minHeight: "100vh",
      }}
    >
      <div style={{ maxWidth: 800, margin: "0 auto" }}>
        {/* Header */}
        <div
          style={{
            display: "flex",
            justifyContent: "space-between",
            marginBottom: 40,
            alignItems: "center",
          }}
        >
          <div>
            <h1 style={{ margin: 0, fontSize: 32, fontWeight: 800 }}>
              Your Maps
            </h1>
            <p style={{ margin: "8px 0 0", color: "#64748b", fontSize: 14 }}>
              Logged in as <strong>{user}</strong>
            </p>
          </div>
          <div style={{ display: "flex", gap: 10 }}>
            <button
              onClick={createProject}
              style={{
                padding: "10px 16px",
                background: "#3b82f6",
                color: "white",
                border: "none",
                borderRadius: 8,
                cursor: "pointer",
                fontWeight: "bold",
                fontSize: 14,
              }}
            >
              + New Map
            </button>
            <button
              onClick={onLogout}
              style={{
                padding: "10px 16px",
                background: "white",
                color: "#ef4444",
                border: "1px solid #fca5a5",
                borderRadius: 8,
                cursor: "pointer",
                fontWeight: "bold",
                fontSize: 14,
              }}
            >
              Sign Out
            </button>
          </div>
        </div>

        {/* Projects Grid */}
        {loading ? (
          <div style={{ textAlign: "center", padding: 60, color: "#64748b" }}>
            Loading maps...
          </div>
        ) : (
          <div
            style={{
              display: "grid",
              gridTemplateColumns: "repeat(auto-fill, minmax(240px, 1fr))",
              gap: 20,
            }}
          >
            {projects.map((p) => (
              <ProjectCard
                key={p.id}
                project={p}
                onOpen={() => onSelectProject(p.id)}
                onDelete={() => deleteProject(p.id)}
              />
            ))}
            {projects.length === 0 && (
              <div
                style={{
                  gridColumn: "1 / -1",
                  textAlign: "center",
                  padding: 60,
                  border: "2px dashed #cbd5e1",
                  borderRadius: 12,
                  color: "#64748b",
                }}
              >
                No maps found. Click "+ New Map" to start.
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

interface ProjectCardProps {
  project: MapProject;
  onOpen: () => void;
  onDelete: () => void;
}

/**
 * ProjectCard Component
 * Individual project card in the grid
 */
function ProjectCard({ project, onOpen, onDelete }: ProjectCardProps) {
  return (
    <div
      style={{
        background: "white",
        padding: 20,
        borderRadius: 12,
        border: "1px solid #e2e8f0",
        boxShadow: "0 4px 6px -1px rgba(0,0,0,0.05)",
        display: "flex",
        flexDirection: "column",
      }}
    >
      <h3 style={{ margin: "0 0 10px 0", fontSize: 16, fontWeight: 700 }}>
        {project.name}
      </h3>
      <p
        style={{
          margin: "0 0 20px 0",
          fontSize: 12,
          color: "#94a3b8",
        }}
      >
        Updated: {new Date(project.updatedAt).toLocaleDateString()}
      </p>
      <div style={{ marginTop: "auto", display: "flex", gap: 8 }}>
        <button
          onClick={onOpen}
          style={{
            flex: 1,
            padding: "8px",
            background: "#eff6ff",
            color: "#2563eb",
            border: "1px solid #bfdbfe",
            borderRadius: 6,
            fontWeight: 600,
            cursor: "pointer",
            fontSize: 13,
          }}
        >
          Open
        </button>
        <button
          onClick={onDelete}
          style={{
            padding: "8px 12px",
            background: "#fef2f2",
            color: "#ef4444",
            border: "1px solid #fecaca",
            borderRadius: 6,
            cursor: "pointer",
            fontSize: 14,
          }}
        >
          🗑️
        </button>
      </div>
    </div>
  );
}
